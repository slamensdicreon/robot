# Anthropic API key for the multimodal scoring model
ANTHROPIC_API_KEY=

# SerpAPI key for search-fallback URL resolution (optional).
# If unset, resolution stops at HTTP HEAD candidate probing.
SERP_API_KEY=

# Where captured screenshots are written. Local path or s3:// URI.
# (Local filesystem is implemented; s3:// is a Phase 2 placeholder.)
SCREENSHOT_STORAGE_PATH=./screenshots

# SQLite database file path (Postgres support is a future phase).
DATABASE_URL=./data/assessments.sqlite

# Default number of accounts processed simultaneously in a batch.
MAX_CONCURRENT_WORKERS=5

# Per-request fetch timeout in milliseconds.
FETCH_TIMEOUT_MS=10000

# Vision-capable scoring model.
SCORE_MODEL=claude-sonnet-4-6

# Port for the dashboard server.
PORT=3000
