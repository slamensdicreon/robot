# Anthropic API key for the multimodal scoring model (required for scoring).
ANTHROPIC_API_KEY=

# SerpAPI key for search-fallback URL resolution (optional).
SERP_API_KEY=

# Database connection. The backend is chosen automatically:
#   postgres://… or postgresql://…  → Neon serverless driver (use this on Vercel)
#   anything else (a file path)      → local SQLite file (zero-config local dev)
# Local default:
DATABASE_URL=./data/assessments.sqlite
# Vercel / production example (set via Vercel Postgres or Neon):
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Where captured screenshots are written locally. Ignored on Vercel
# (serverless can't run headless Chromium, so scoring is HTML-only there).
SCREENSHOT_STORAGE_PATH=./screenshots

# Per-request fetch timeout in milliseconds.
FETCH_TIMEOUT_MS=10000

# Vision-capable scoring model.
SCORE_MODEL=claude-sonnet-4-6

# Port for local dev server.
PORT=3000
